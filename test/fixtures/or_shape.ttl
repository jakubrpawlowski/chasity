@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:CreditCardShape
	a sh:NodeShape ;
	sh:targetClass ex:CreditCard ;
	sh:property [
		sh:path ex:cardNumber ;
		sh:datatype xsd:string ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

ex:BankAccountShape
	a sh:NodeShape ;
	sh:targetClass ex:BankAccount ;
	sh:property [
		sh:path ex:accountNumber ;
		sh:datatype xsd:string ;
		sh:minCount 1 ;
		sh:maxCount 1
	] .

ex:PaymentShape
	a sh:NodeShape ;
	sh:targetClass ex:Payment ;
	sh:property [
		sh:path ex:amountCents ;
		sh:datatype xsd:integer ;
		sh:minCount 1 ;
		sh:maxCount 1 ;
		sh:name "Amount in cents"
	] , [
		sh:path ex:paidWith ;
		sh:or (
			[
				sh:class ex:CreditCard
			]
			[
				sh:class ex:BankAccount
			]
		) ;
		sh:minCount 1 ;
		sh:name "Paid with"
	] .
